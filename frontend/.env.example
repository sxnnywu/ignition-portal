# frontend/.env.example
# Copy this file to frontend/.env (or .env.local) and fill in values.
# Vite only exposes variables prefixed with VITE_ to the client (import.meta.env).

# --- API base URL ---
# OPTIONAL. Base URL the frontend prefixes onto every API call (see
# src/lib/api.js apiUrl()). When unset/empty, requests use relative paths and the
# Vite dev proxy forwards them to the backend — leave it BLANK in local dev.
# In production set this to the backend's public URL, e.g.
#   VITE_API_BASE_URL=https://api.ignitionhacks.com
# A trailing slash is stripped automatically; no path segment, origin only.
VITE_API_BASE_URL=
