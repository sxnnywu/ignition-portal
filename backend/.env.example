# backend/.env.example
# Copy this file to backend/.env and fill in real values. NEVER commit the real .env.
# Every variable below is read somewhere in backend/src (see docs/environment-variables.md).

# --- Database ---
# MongoDB connection string. The DB name (e.g. ignition-portal) must come right
# after the host, before the "?" — otherwise Mongoose uses the "test" database.
# NOTE: the variable is MONGO_URI (read in src/config/db.js), not MONGODB_URI.
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/ignition-portal?retryWrites=true&w=majority

# --- Auth ---
# Secret used to sign/verify JWTs. Use a long random string (32+ chars) in prod;
# changing it invalidates all existing tokens.
JWT_SECRET=change_me_to_a_long_random_string

# Passphrases required to self-register privileged accounts via
# POST /signup/reviewer and POST /signup/admin (the "secret" field).
REVIEWER_SIGNUP_SECRET=change_me_reviewer_secret
ADMIN_SIGNUP_SECRET=change_me_admin_secret

# --- CORS ---
# Comma-separated list of allowed frontend origins. In PRODUCTION set this to the
# real deployed frontend origin only — do NOT use "*". If left empty/unset the
# server falls back to allowing all origins (src/app.js), which is dev-only.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Email (password reset + any notification mail) ---
# Provider for nodemailer (e.g. gmail). For Gmail use an App Password, not your
# account password: https://support.google.com/accounts/answer/185833
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_app_password_here

# Public URL of the deployed frontend. Used to build the password-reset link
# (FRONTEND_URL/reset-password?token=...). Must point at the real frontend in prod.
FRONTEND_URL=http://localhost:5173

# --- Server ---
# Port the Express server listens on (default 8000 if unset). The Vite dev proxy
# in frontend/vite.config.js forwards to http://localhost:8000 — keep them in sync.
PORT=8000
